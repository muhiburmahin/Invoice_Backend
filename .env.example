# Copy to .env and fill in values

# Required in production (32+ random bytes). Dev fallback exists only when NODE_ENV !== production.
BETTER_AUTH_SECRET=

# Public URL of this API (Better Auth callbacks / redirects)
BETTER_AUTH_URL=http://localhost:5000

DATABASE_URL=
CLIENT_URL=http://localhost:5173

# Optional – enable Google sign-in when both are set
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional – enable GitHub sign-in when both are set
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
