# Invoice API — copy to `.env` and adjust

NODE_ENV=development
PORT=5000

# Required
DATABASE_URL=postgresql://user:password@localhost:5432/invoice

# Auth / SaaS web app (FRONTEND_URL / APP_URL also accepted as aliases)
CLIENT_URL=http://localhost:3000
# Comma-separated if you have app + admin + marketing origins
# CORS_ORIGINS=http://localhost:3000

# Reverse proxy (Render, Fly, k8s ingress)
TRUST_PROXY=false

REQUEST_TIMEOUT_MS=30000

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

BETTER_AUTH_SECRET=change-me-min-32-chars-for-production-abcdef
BETTER_AUTH_URL=http://localhost:5000

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

LOG_LEVEL=debug

# Future: BullMQ / Inngest
REDIS_URL=

# Transactional email (optional — legacy EMAIL_* / EMAIL_SENDER_SMTP_* also work)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourdomain.com

# File uploads (optional)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Billing webhooks (optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_ENTERPRISE_MONTHLY=
# Used when STRIPE_PRICE_PRO_MONTHLY is empty (1900 = $19.00/month)
STRIPE_PRO_AMOUNT=1900
STRIPE_PRO_CURRENCY=usd

# Offline plan upgrade (bKash / bank transfer — admin activates manually)
FEATURE_OFFLINE_BILLING=false
OFFLINE_PRO_PRICE=999
OFFLINE_PRO_CURRENCY=BDT
OFFLINE_PAYMENT_BKASH=
OFFLINE_PAYMENT_NAGAD=
OFFLINE_PAYMENT_BANK_NAME=
OFFLINE_PAYMENT_BANK_ACCOUNT=
OFFLINE_PAYMENT_INSTRUCTIONS=

# Feature flags
FEATURE_BILLING=false
FEATURE_AUDIT_LOG=false
FEATURE_SCHEDULED_JOBS=false
# How often background jobs run when enabled (ms). Default in code: 3600000 (1 hour)
SCHEDULED_JOBS_INTERVAL_MS=3600000
